{
  "scenario_name": "crm",
  "seed": 42,
  "simulation": {
    "start_date": "2025-03-30",
    "end_date": "2026-03-30"
  },
  "entities": {
    "Customers": {
      "fields": {
        "customer_segment": {
          "distribution": "categorical",
          "params": {
            "categories": [
              "Mass",
              "Affluent",
              "SME"
            ]
          }
        }
      }
    },
    "Accounts": {
      "fields": {
        "balance": {
          "distribution": "lognormal",
          "params": {
            "mean": 5000,
            "sigma": 0.8
          }
        },
        "account_type": {
          "distribution": "categorical",
          "params": {
            "categories": [
              "Standard",
              "Premium",
              "Enterprise"
            ]
          }
        }
      }
    },
    "Transactions": {
      "fields": {
        "amount": {
          "distribution": "lognormal",
          "params": {
            "mean": 5000,
            "sigma": 0.8
          }
        },
        "transaction_type": {
          "distribution": "categorical",
          "params": {
            "categories": [
              "Standard",
              "Premium",
              "Enterprise"
            ]
          }
        }
      }
    },
    "Customer_Interactions": {
      "fields": {
        "interaction_type": {
          "distribution": "categorical",
          "params": {
            "categories": [
              "Standard",
              "Premium",
              "Enterprise"
            ]
          }
        }
      }
    }
  },
  "generation_order": [
    "Customers",
    "Accounts",
    "Customer_Interactions",
    "Transactions"
  ],
  "table_counts": {
    "Customers": 1000,
    "Accounts": 1400,
    "Customer_Interactions": 2500,
    "Transactions": 2500
  },
  "state_machines": {
    "Accounts": {
      "state_field": "account_status",
      "initial_state": "Pending",
      "terminal_states": [
        "Closed"
      ],
      "transitions": {
        "Pending": {
          "Active": {
            "base_prob": 0.85,
            "adjustments": [
              {
                "field": "balance",
                "direction": "higher_increases",
                "strength": "moderate"
              },
              {
                "field": "account_type",
                "direction": "higher_increases",
                "strength": "weak"
              }
            ]
          },
          "Closed": {
            "base_prob": 0.15,
            "adjustments": []
          }
        },
        "Active": {
          "Active": {
            "base_prob": 0.85,
            "adjustments": []
          },
          "Dormant": {
            "base_prob": 0.14,
            "adjustments": [
              {
                "field": "balance",
                "direction": "higher_increases",
                "strength": "moderate"
              },
              {
                "field": "account_type",
                "direction": "higher_increases",
                "strength": "weak"
              }
            ]
          },
          "Closed": {
            "base_prob": 0.01,
            "adjustments": []
          }
        },
        "Dormant": {
          "Active": {
            "base_prob": 0.1,
            "adjustments": []
          },
          "Dormant": {
            "base_prob": 0.8,
            "adjustments": []
          },
          "Closed": {
            "base_prob": 0.1,
            "adjustments": [
              {
                "field": "balance",
                "direction": "higher_increases",
                "strength": "moderate"
              },
              {
                "field": "account_type",
                "direction": "higher_increases",
                "strength": "weak"
              }
            ]
          }
        }
      }
    }
  },
  "events": {
    "Transactions": {
      "emitted_by": "Accounts",
      "emit_when_states": [
        "Active"
      ],
      "frequency": {
        "distribution": "poisson",
        "lambda_base": 5.0,
        "lambda_modifiers": [
          {
            "field": "balance",
            "effect": "higher_increases"
          },
          {
            "field": "account_type",
            "effect": "higher_increases"
          }
        ]
      },
      "fields": {}
    }
  },
  "constraints": [
    {
      "type": "temporal_order",
      "params": {
        "fields": [
          "date_of_birth",
          "onboarding_date"
        ]
      }
    },
    {
      "type": "temporal_order",
      "params": {
        "fields": [
          "opening_date",
          "closing_date",
          "last_status_change_timestamp"
        ]
      }
    }
  ]
}