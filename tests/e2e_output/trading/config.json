{
  "scenario_name": "trading",
  "seed": 42,
  "simulation": {
    "start_date": "2025-03-30",
    "end_date": "2026-03-30"
  },
  "entities": {
    "Traders": {
      "fields": {}
    },
    "Orders": {
      "fields": {
        "quantity": {
          "distribution": "lognormal",
          "params": {
            "mean": 1000,
            "sigma": 0.8
          }
        },
        "price": {
          "distribution": "lognormal",
          "params": {
            "mean": 100,
            "sigma": 0.5
          }
        }
      }
    },
    "TradeExecutions": {
      "fields": {
        "executed_quantity": {
          "distribution": "lognormal",
          "params": {
            "mean": 1000,
            "sigma": 0.8
          }
        },
        "executed_price": {
          "distribution": "lognormal",
          "params": {
            "mean": 100,
            "sigma": 0.5
          }
        }
      }
    },
    "Settlements": {
      "fields": {}
    }
  },
  "generation_order": [
    "Traders",
    "Orders",
    "TradeExecutions",
    "Settlements"
  ],
  "table_counts": {
    "Traders": 1000,
    "Orders": 2500,
    "TradeExecutions": 1000,
    "Settlements": 1600
  },
  "state_machines": {
    "Orders": {
      "state_field": "order_status",
      "initial_state": "Open",
      "terminal_states": [
        "Filled",
        "Cancelled"
      ],
      "transitions": {
        "Open": {
          "Open": {
            "base_prob": 0.4,
            "adjustments": []
          },
          "Partial Fill": {
            "base_prob": 0.2,
            "adjustments": [
              {
                "field": "instrument_type",
                "direction": "higher_increases",
                "strength": "weak"
              }
            ]
          },
          "Filled": {
            "base_prob": 0.3,
            "adjustments": [
              {
                "field": "instrument_type",
                "direction": "higher_increases",
                "strength": "weak"
              }
            ]
          },
          "Cancelled": {
            "base_prob": 0.1,
            "adjustments": []
          }
        },
        "Partial Fill": {
          "Partial Fill": {
            "base_prob": 0.3,
            "adjustments": []
          },
          "Filled": {
            "base_prob": 0.6,
            "adjustments": [
              {
                "field": "instrument_type",
                "direction": "higher_increases",
                "strength": "weak"
              }
            ]
          },
          "Cancelled": {
            "base_prob": 0.1,
            "adjustments": []
          }
        }
      }
    }
  },
  "events": {
    "TradeExecutions": {
      "emitted_by": "Orders",
      "emit_when_states": [
        "Open",
        "Partial Fill"
      ],
      "frequency": {
        "distribution": "poisson",
        "lambda_base": 2.0,
        "lambda_modifiers": [
          {
            "field": "instrument_type",
            "effect": "higher_increases"
          }
        ]
      },
      "fields": {}
    },
    "Settlements": {
      "emitted_by": "Orders",
      "emit_when_states": [
        "Open",
        "Partial Fill"
      ],
      "frequency": {
        "distribution": "poisson",
        "lambda_base": 2.0,
        "lambda_modifiers": [
          {
            "field": "instrument_type",
            "effect": "higher_increases"
          }
        ]
      },
      "fields": {}
    }
  },
  "constraints": [
    {
      "type": "temporal_order",
      "params": {
        "fields": [
          "settlement_date",
          "last_update_timestamp"
        ]
