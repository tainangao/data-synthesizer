{
  "scenario_name": "credit_risk",
  "seed": 42,
  "simulation": {
    "start_date": "2025-03-30",
    "end_date": "2026-03-30"
  },
  "entities": {
    "Customers": {
      "fields": {
        "credit_score": {
          "distribution": "normal",
          "params": {
            "mean": 650,
            "std": 100
          }
        },
        "income": {
          "distribution": "lognormal",
          "params": {
            "mean": 60000,
            "sigma": 0.5
          }
        }
      }
    },
    "CreditScores": {
      "fields": {}
    },
    "LoanApplications": {
      "fields": {}
    },
    "LoanAccounts": {
      "fields": {}
    },
    "LoanPayments": {
      "fields": {}
    },
    "DelinquencyEvents": {
      "fields": {}
    }
  },
  "generation_order": [
    "Customers",
    "CreditScores",
    "LoanApplications",
    "LoanAccounts",
    "DelinquencyEvents",
    "LoanPayments"
  ],
  "table_counts": {
    "Customers": 1000,
    "CreditScores": 1600,
    "LoanApplications": 1000,
    "LoanAccounts": 1000,
    "DelinquencyEvents": 1600,
    "LoanPayments": 1600
  },
  "state_machines": {
    "LoanApplications": {
      "state_field": "application_status",
      "initial_state": "Pending",
      "terminal_states": [
        "Approved",
        "Rejected"
      ],
      "transitions": {
        "Pending": {
          "Approved": {
            "base_prob": 0.7,
            "adjustments": []
          },
          "Rejected": {
            "base_prob": 0.3,
            "adjustments": []
          }
        }
      }
    }
  },
  "events": {
    "LoanPayments": {
      "emitted_by": "LoanApplications",
      "emit_when_states": [
        "Current",
        "Delinquent"
      ],
      "frequency": {
        "distribution": "poisson",
        "lambda_base": 1.0,
        "lambda_modifiers": []
      },
      "fields": {}
    }
  },
  "constraints": [
    {
      "type": "temporal_order",
      "params": {
        "fields": [
          "date_of_birth",
          "onboarding_date"
        ]
      }
    },
    {
      "type": "temporal_order",
      "params": {
        "fields": [
          "origination_date",
          "next_payment_due_date"
        ]
      }
    }
  ]
}